# Maaleh Warehouse — Environment variables
# העתק קובץ זה ל-.env והגדר את הערכים. אל תכניס את .env ל-git.

# Environment: development / production
ENV=production

# JWT secret — חובה ב-production!
# ייצור secret חדש:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# תוקף טוקן בימים (ברירת מחדל 7)
ACCESS_TOKEN_EXPIRE_DAYS=7

# רשימת דומיינים מורשים לקריאה ל-API, מופרדים בפסיק
# לדוגמה: https://warehouse.maale.co.il,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Rate limiting — מספר ניסיונות login לכל IP בדקה
LOGIN_RATE_LIMIT=5
